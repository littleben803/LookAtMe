    "legal.privacy.local_first" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Look My Way 2.0 is a local-first tool. It does not use accounts, servers, ad tracking, or online AI."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "こっち向いて 2.0 はローカル優先のツールです。アカウント、サーバー、広告トラッキング、オンラインAIは利用しません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "想恋爱 2.0 是一款本地优先工具，不接入账号、服务端、广告追踪或在线 AI。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "想戀愛 2.0 是一款本機優先工具，不接入帳號、服務端、廣告追蹤或線上 AI。"
          }
        }
      }
    },
    "legal.privacy.pro_locked" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you use Pro features, purchases are handled by the Apple App Store. We do not access or store your payment account, card details, or Apple ID password."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro機能を利用する場合、取引はApple App Storeによって処理されます。支払いアカウント、カード情報、Apple IDのパスワードを取得または保存することはありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如你使用高级权益，交易由 Apple App Store 处理。我们不会获取或保存你的付款账号、银行卡信息或 Apple ID 密码。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如你使用進階權益，交易由 Apple App Store 處理。我們不會取得或儲存你的付款帳號、銀行卡資訊或 Apple ID 密碼。"
          }
        }
      }
    },
    "legal.privacy.pro_unlocked" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As a Pro user, you have unlocked premium styles, templates, fonts, unlimited favorites, and custom style saving. Entitlement checks use Apple App Store purchase records. We do not access or store your payment account, card details, or Apple ID password."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proユーザーは、プレミアムスタイル、テンプレート、フォント、無制限のお気に入り、カスタムスタイル保存などを利用できます。権利確認はApple App Storeの購入記録に基づきます。支払いアカウント、カード情報、Apple IDのパスワードを取得または保存することはありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "尊敬的 Pro 用户，你已解锁全部高级样式、高级模板、高级字体、无限收藏和自定义样式保存等能力。你的权益校验以 Apple App Store 的购买记录为准，我们不会获取或保存你的付款账号、银行卡信息或 Apple ID 密码。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "尊敬的 Pro 使用者，你已解鎖全部進階樣式、進階模板、進階字體、無限收藏和自訂樣式儲存等能力。你的權益校驗以 Apple App Store 的購買記錄為準，我們不會取得或儲存你的付款帳號、銀行卡資訊或 Apple ID 密碼。"
          }
        }
      }
    },
