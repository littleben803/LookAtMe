    "about.app_name" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Look My Way"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "こっち向いて"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "想恋爱"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "想戀愛"
          }
        }
      }
    },
    "about.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turn your phone into a glowing love banner. A classic iOS app returns with a prettier, easier banner experience for concerts, confessions, birthdays, and pickups."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スマホを光る応援・告白ボードに変えます。懐かしいiOSアプリが、ライブ、告白、誕生日、出迎えで使いやすい、よりきれいなボード体験として戻ってきました。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把手机变成会发光的表白灯牌。经典 iOS 应用全新回归，为演唱会、表白、生日和接机场景提供更漂亮、更好用的灯牌体验。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把手機變成會發光的表白燈牌。經典 iOS App 全新回歸，為演唱會、表白、生日和接機場景提供更漂亮、更好用的燈牌體驗。"
          }
        }
      }
    },
    "about.title" : {
